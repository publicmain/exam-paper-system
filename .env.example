# =====================================================================
# Exam Paper System — environment variables
#
# Copy to `.env` for local dev. In production set every variable explicitly;
# main.ts refuses to start in NODE_ENV=production with the dev-default
# JWT_SECRET, and a missing CORS_ORIGINS in prod is a hard fail.
# =====================================================================

# ---- Postgres ---------------------------------------------------------
DATABASE_URL=postgresql://exam:exam@localhost:5432/exam_paper_system?schema=public

# ---- API --------------------------------------------------------------
API_PORT=4000
# In production set NODE_ENV=production. The bootstrap runs strict checks
# only in this mode (JWT default refusal, CORS allowlist required).
NODE_ENV=development
# Generate a long random string for prod: openssl rand -hex 64
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
# Comma-separated allowlist of origins permitted to make CORS-credentialed
# requests. In prod set to the deployed web origin only, e.g.
# https://exam.school.edu — the API refuses to start without this in prod.
CORS_ORIGINS=

# ---- Frontend (Vite reads VITE_*) -------------------------------------
VITE_API_URL=http://localhost:4000

# ---- Anthropic (Claude API) -------------------------------------------
ANTHROPIC_API_KEY=sk-ant-replace-with-your-real-key
ANTHROPIC_MODEL=claude-sonnet-4-6
# Hard cap on Anthropic spend per calendar month — once exceeded, AI
# generation / QA / short-answer evaluation refuse with a clear error
# rather than silently rack up cost. Set per deployment budget.
ANTHROPIC_MONTHLY_USD_CAP=200

# ---- OpenAI (image generation only) -----------------------------------
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_MONTHLY_USD_CAP=50

# ---- Tutor / 1:1 Path-B -----------------------------------------------
# Per-student daily USD cap on AI tutor sessions. Defends against a
# single student accidentally burning the whole monthly budget.
TUTOR_DAILY_USD_PER_STUDENT_CAP=2

# ---- Storage (MVP: local filesystem) ----------------------------------
STORAGE_DIR=./uploads
# Override for AI-generated images and rendered PDFs if you want them
# elsewhere on the host (Railway volumes, etc.).
AI_IMAGE_STORAGE_PATH=
RENDER_STORAGE_PATH=
RAW_STORAGE_PATH=

# ---- Internal service-to-service ---------------------------------------
# Shared bearer the API sends to pdf-worker on /render_*. Generate a
# random hex string. The pdf-worker refuses unauthenticated requests
# in production once this is set on both sides.
INTERNAL_API_TOKEN=
# Where the API reaches the pdf-worker. Inside Railway this is the
# private networking host:port; locally it's http://localhost:5005.
PDF_WORKER_URL=http://localhost:5005
# Public-facing API origin used in QR scan links and emails. Required
# in prod so QR codes resolve to the deployed web origin, not localhost.
PUBLIC_API_URL=http://localhost:4000

# ---- Puppeteer / PDF --------------------------------------------------
PDF_TIMEOUT_MS=30000

# ---- Morning Quiz (scheduling) ----------------------------------------
# NOTE: the school-WiFi IP allowlist was removed (the school's WiFi was
# too unreliable to gate on). SCHOOL_PUBLIC_IPS / SCHOOL_IP_BYPASS /
# SCHOOL_IP_BYPASS_UNTIL are no longer read by the API — students scan
# from any network. The scan flow is still gated by a live QR token,
# roster membership, the attendance time window, and in-room
# invigilation.
# Display label that appears on the QR big-screen page.
SCHOOL_NAME=Demo School
# Local-time offset used by createSession / cron when materialising the
# 8:30/8:32/8:50/9:00 windows. Default is +08:00 = 480 min.
MORNING_QUIZ_TZ_OFFSET_MIN=480
# DEBUG ONLY — exposes the /sessions/:id/debug-activate endpoint that
# fast-forwards a session into 'active' for off-hours smoke testing.
# Audit-logged. Always false in production.
MORNING_QUIZ_DEBUG=false
# Sunday-night auto-generate cron toggle. When true the cron at 18:00
# every Sunday runs batchGenerateForWeek for every class with an
# english-level row. False today (Dan still does generation manually).
MORNING_QUIZ_AUTO_GENERATE=false
# Daily 7:30am consecutive-absence sweep that fires wechat alerts when
# a student has missed N+ days in a row.
MORNING_QUIZ_ABSENCE_ALERTS=false

# ---- Demo / mock auth -------------------------------------------------
# Set true to allow login without real password check. NEVER true in prod.
MOCK_AUTH=false

# ---- Seed safety ------------------------------------------------------
# prisma/seed.ts creates demo accounts with weak passwords; running it in
# production is a privilege escalation. Set to 'true' only if you really
# want to seed a production install (e.g. fresh internal deploy).
ALLOW_PROD_SEED=false
