# Postgres
DATABASE_URL=postgresql://exam:exam@localhost:5432/exam_paper_system?schema=public

# API
API_PORT=4000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Frontend (Vite reads VITE_*)
VITE_API_URL=http://localhost:4000

# Anthropic (Claude API for AI labeling)
ANTHROPIC_API_KEY=sk-ant-replace-with-your-real-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Storage (MVP: local filesystem)
STORAGE_DIR=./uploads

# Puppeteer / PDF
PDF_TIMEOUT_MS=30000

# Demo / mock auth (set true to allow login without real password check)
MOCK_AUTH=false
