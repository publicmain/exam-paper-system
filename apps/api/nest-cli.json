{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "pdf/templates/**/*.html", "outDir": "dist" },
      { "include": "pdf/templates/**/*.css", "outDir": "dist" }
    ]
  }
}
