generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Users & Auth
// ============================================================
enum UserRole {
  teacher
  head_teacher
  admin
  student
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         UserRole  @default(teacher)
  // B6 — admin can deactivate a user without deleting the row. AuthService
  // login should reject when isActive=false (returns the same generic 401
  // as a wrong password to avoid user-enumeration).
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  lastLogin    DateTime?
  // R14 — Feature 12: soft-archive a student (or any user) without
  // deleting the row. Login + roster queries filter `archivedAt IS NULL`
  // by default; admin can un-archive by clearing the column.
  archivedAt   DateTime?

  questionsCreated             Question[]               @relation("QuestionCreator")
  templatesOwned               PaperTemplate[]
  papersOwned                  Paper[]
  versionsAuthored             PaperVersion[]
  questionVersions             QuestionVersion[]
  reposAdded                   SourceRepository[]       @relation("RepoAddedBy")
  questionItemReviewed         QuestionItem[]           @relation("QuestionItemReviewer")
  teacherReviews               TeacherReview[]          @relation("ReviewActor")
  classEnrollments             ClassEnrollment[]
  paperAssignmentsMade         PaperAssignment[]        @relation("PaperAssignedBy")
  submissions                  StudentSubmission[]
  // Path-B back-relations
  markerAssignments            MarkerAssignment[]       @relation("MarkerAssignmentMarker")
  paperVariants                PaperVariantAssignment[] @relation("PaperVariantStudent")
  tutorSessions                TutorSession[]
  watermarkTokens              WatermarkToken[]         @relation("WatermarkTokenStudent")
  // Morning quiz back-relations
  morningQuizSessionsScheduled MorningQuizSession[]     @relation("MorningQuizScheduledBy")
  attendances                  Attendance[]             @relation("AttendanceStudent")
  attendancesCorrected         Attendance[]             @relation("AttendanceCorrectedBy")
  shuffleMaps                  QuestionShuffleMap[]     @relation("ShuffleMapStudent")
  // R14 back-relations — Features 10, 12, 14, 15
  appealsReviewed              GradeAppeal[]            @relation("AppealReviewer")
  classTransfers               ClassTransferLog[]       @relation("TransferStudent")
  classTransfersActed          ClassTransferLog[]       @relation("TransferActor")
  parentLinks                  ParentLink[]             @relation("ParentLinkStudent")
  parentLinksCreated           ParentLink[]             @relation("ParentLinkCreator")
  questionRetractions          QuestionRetraction[]     @relation("RetractionActor")
  // Homework M1 back-relations
  coursesCreated               Course[]                 @relation("CourseCreator")
  homeworksCreated             Homework[]               @relation("HomeworkCreator")
  homeworkAssignmentsMade      HomeworkAssignment[]     @relation("HomeworkAssignedBy")
  homeworkSubmissions          HomeworkSubmission[]     @relation("HomeworkSubmissionStudent")
  homeworkGraded               HomeworkGrade[]          @relation("HomeworkGradedBy")
  regradeRequests              RegradeRequest[]         @relation("RegradeStudent")
  regradeReplies               RegradeRequest[]         @relation("RegradeRepliedBy")
  notifications                Notification[]           @relation("UserNotifications")
}

// ============================================================
// Block 1: Student-side — classes, assignments, submissions
// ============================================================
model Class {
  id         String    @id @default(cuid())
  name       String // "Form 5B", "IAL26S1"
  classCode  String    @unique // short join code, e.g. "FORM5B"
  // B3-H4 removed: the previous `level String?` field collided with
  // ClassEnglishLevel.level (the actually-load-bearing morning-quiz
  // enum) and was never read by any logic. ClassEnglishLevel is the
  // single source of truth for class proficiency. If a future feature
  // needs a non-English course-level, add it as a separate field.
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  // R14 — Feature 6: class soft-delete. Listing endpoints filter
  // `archivedAt IS NULL` by default so an archived class disappears
  // from teacher rosters without breaking historical enrolments / papers.
  archivedAt DateTime?

  // F5: per-class teacher-supplied "weekly focus" string. The AI quick-
  // paper prompt picks this up so generated questions emphasise the
  // teacher-stated areas (e.g. "本周重点 matching headings + collocation").
  // null when the teacher hasn't set anything; the prompt then falls
  // back to the syllabus-default mix.
  weeklyFocus String?

  enrollments         ClassEnrollment[]
  assignments         PaperAssignment[]
  // Morning quiz back-relations
  morningQuizSessions MorningQuizSession[]
  // R10 — multi-level: was englishLevel ClassEnglishLevel? (1:1).
  // A class can now register multiple difficulty bands at once.
  englishLevels       ClassEnglishLevel[]
  // R14 — Feature 12: class-transfer audit trail back-relations.
  transfersFrom       ClassTransferLog[]   @relation("TransferFrom")
  transfersTo         ClassTransferLog[]   @relation("TransferTo")
  // Homework M1 back-relation
  homeworkAssignments HomeworkAssignment[]
}

model ClassEnrollment {
  id       String   @id @default(cuid())
  classId  String
  class    Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // 'student' | 'class_teacher' (homeroom) | 'subject_teacher'.
  // String not enum to allow per-school customisation later.
  role     String   @default("student")
  joinedAt DateTime @default(now())

  @@unique([classId, userId])
  @@index([userId])
}

model PaperAssignment {
  id           String    @id @default(cuid())
  paperId      String
  paper        Paper     @relation(fields: [paperId], references: [id], onDelete: Cascade)
  classId      String
  class        Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  assignedById String
  // B4: Restrict — assigning teacher is part of the audit trail.
  assignedBy   User      @relation("PaperAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)
  assignedAt   DateTime  @default(now())
  startAt      DateTime?
  dueAt        DateTime?
  durationMin  Int?
  // 'scheduled' (before startAt) | 'open' (between start and due) | 'closed' (past due)
  status       String    @default("scheduled")

  submissions        StudentSubmission[]
  // Path-B back-relations
  variantAssignments PaperVariantAssignment[]
  watermarkTokens    WatermarkToken[]
  // Morning quiz back-relation (1:1 optional)
  morningQuizSession MorningQuizSession?

  @@unique([paperId, classId])
  @@index([classId])
}

model StudentSubmission {
  id           String          @id @default(cuid())
  assignmentId String
  assignment   PaperAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  // B4: Restrict so deleting a student doesn't drop their submission
  // history (grade audit trail must survive account churn).
  student      User            @relation(fields: [studentId], references: [id], onDelete: Restrict)
  startedAt    DateTime        @default(now())
  submittedAt  DateTime?
  // in_progress | submitted | marked | returned
  status       String          @default("in_progress")
  // Auto-graded portion (MCQ items) computed on submit
  autoScore    Float?
  // Manually-marked portion (structured items) summed across scripts
  manualScore  Float?
  // autoScore + manualScore, surfaced in the dashboard
  totalScore   Float?
  // Snapshot of paper.totalMarksActual at submission time
  maxScore     Int

  scripts           AnswerScript[]
  // Path-B back-relations
  markerAssignments MarkerAssignment[]
  tutorSessions     TutorSession[]
  // Morning quiz back-relation (1:1 optional)
  attendance        Attendance?
  // R14 — Feature 10: appeals filed against this submission.
  appeals           GradeAppeal[]

  // R14 — Feature 16 (practice mode): the original `@@unique([assignmentId,
  // studentId])` blocked a student from having a `practice` submission
  // alongside their real `submitted` submission for the same paper.
  // Postgres unique indexes can't have a WHERE filter via Prisma schema,
  // so we drop the constraint and enforce non-practice uniqueness at the
  // service-layer (`student.service.finalSubmit` + the assign-paper flow
  // already do `findFirst` before creating). Practice subs are written
  // freely and are filtered out everywhere by `status != 'practice'`.
  @@index([assignmentId, studentId])
  @@index([studentId])
  // Round-7 H17 (agent-3 D9): MarkerService.listQueue filters by
  // `status='submitted'` AND has-ungraded-script. Without (assignmentId,
  // status) the planner falls back to the unique on (assignmentId,
  // studentId), then filters in memory. With this composite the queue
  // browse stays fast as submissions accumulate.
  @@index([assignmentId, status])
}

model AnswerScript {
  id              String                @id @default(cuid())
  submissionId    String
  submission      StudentSubmission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  paperQuestionId String
  paperQuestion   PaperQuestion         @relation(fields: [paperQuestionId], references: [id], onDelete: Cascade)
  // MCQ: option key 'A'/'B'/'C'/'D'. Structured: textAnswer carries body.
  selectedOption  String?
  textAnswer      String?
  // Marker fills these for structured items; auto-fill for MCQ.
  awardedMarks    Float?
  markerComment   String?
  markedById      String?
  markedAt        DateTime?
  // Auto-grade verdict for MCQ; null for structured.
  autoCorrect     Boolean?
  updatedAt       DateTime              @updatedAt
  // Path-B back-relations
  codeResult      CodeSubmissionResult?

  @@unique([submissionId, paperQuestionId])
  @@index([submissionId])
}

// ============================================================
// Reference: Boards / Subjects / Components / Topics
// ============================================================
model ExamBoard {
  id       String    @id @default(cuid())
  code     String    @unique // CIE, EDEXCEL, AQA, OCR
  name     String
  subjects Subject[]
}

model Subject {
  id          String              @id @default(cuid())
  examBoardId String
  examBoard   ExamBoard           @relation(fields: [examBoardId], references: [id], onDelete: Cascade)
  code        String // 9709, 9702
  name        String // Mathematics, Physics
  level       String // A_LEVEL, AS_LEVEL, IGCSE, O_LEVEL
  components  SyllabusComponent[]
  questions   Question[]
  papers      Paper[]
  templates   PaperTemplate[]
  // Homework M1 back-relation
  courses     Course[]

  @@unique([examBoardId, code, level])
}

model SyllabusComponent {
  id        String          @id @default(cuid())
  subjectId String
  subject   Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  code      String // P1, P3, Paper2
  name      String
  topics    Topic[]
  questions Question[]
  papers    Paper[]
  templates PaperTemplate[]

  @@unique([subjectId, code])
}

model Topic {
  id            String            @id @default(cuid())
  componentId   String
  component     SyllabusComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  parentTopicId String?
  parent        Topic?            @relation("TopicHierarchy", fields: [parentTopicId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children      Topic[]           @relation("TopicHierarchy")
  code          String
  name          String
  sortOrder     Int               @default(0)

  primaryForQuestions Question[]          @relation("QuestionPrimaryTopic")
  questionLinks       QuestionTopic[]
  questionItemLinks   QuestionItemTopic[] @relation("ItemTopics")

  @@unique([componentId, code])
}

// ============================================================
// Question Bank
// ============================================================
enum QuestionType {
  mcq
  short_answer
  structured
  essay
}

enum QuestionStatus {
  draft
  active
  retired
}

enum SourceType {
  original_school
  ai_generated
  past_paper_reference
  textbook
}

model Question {
  id             String             @id @default(cuid())
  subjectId      String
  // B4: Restrict — Subject deletion must not silently nuke its question
  // bank; admin has to explicitly re-tag or delete each Question first.
  subject        Subject            @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  componentId    String?
  // B4: SetNull — a deleted SyllabusComponent leaves its Questions
  // orphaned at the subject level (still findable, just no component).
  component      SyllabusComponent? @relation(fields: [componentId], references: [id], onDelete: SetNull)
  primaryTopicId String?
  primaryTopic   Topic?             @relation("QuestionPrimaryTopic", fields: [primaryTopicId], references: [id], onDelete: SetNull)

  questionType     QuestionType
  marks            Int
  estimatedTimeMin Float // default = marks * subject.timePerMark
  difficulty       Int // 1-5
  sourceType       SourceType   @default(original_school)
  sourceRef        String? // e.g. "9702/22/M/J/19/Q3" — metadata only

  // Content as JSON (markdown + LaTeX), supports parts for structured
  // Shape: { stem: string, parts?: [{ label, content, marks, answer }] }
  content       Json
  answerContent Json // { text, parts?: [{ label, answer }] }
  options       Json? // MCQ only: [{ key:'A', text, correct }]
  markScheme    Json? // [{ point, marks }]

  status           QuestionStatus   @default(draft)
  // Compliance gates — questions whose source is restricted past papers must
  // be filtered out of generation by default unless the request explicitly
  // opts in (e.g. school is licensed). New rows default to safe values so
  // existing school-authored / AI-generated content keeps working.
  complianceStatus ComplianceStatus @default(approved_internal)
  allowedUsage     AllowedUsage     @default(free_use)

  // Optional provenance tag used to keep one-click AI output (Quick Paper)
  // out of the default question-generation pool. AI quick-paper questions
  // are tagged 'ai_quick_paper' and excluded from regular paper generation
  // unless the request explicitly opts in via includeAiQuickPaper. This
  // protects other teachers' papers from being filled with un-curated AI
  // questions while still letting the requester use them in their own
  // generated paper.
  provenanceTag String?

  // F4 — knowledge-area tags used to compute per-student weakness profiles.
  // Seeded by the AI generator and back-fillable on legacy rows via the
  // scripts/backfill-question-tags.ts pass. Free-form strings, but
  // typical values are: 'reading_detail', 'vocab', 'grammar', 'inference',
  // 'matching', 'cloze', 'tfng', 'collocation'. Empty array means
  // un-tagged (legacy + un-classified).
  tags String[] @default([])

  createdById String
  // B4: Restrict — keeps Question authorship audit trail intact.
  createdBy   User     @relation("QuestionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topics                 QuestionTopic[]
  assets                 QuestionAsset[]
  versions               QuestionVersion[]
  paperQuestions         PaperQuestion[]
  usageLogs              QuestionUsageLog[]
  ingestedItem           QuestionItem?           @relation("QuestionItemMirror")
  // Path-B back-relations
  qualityFeedbackSignals QuestionQualitySignal[]
  codeTestCases          CodeQuestionTestCase[]
  // Note: tags is String[] — a btree index won't help array-overlap queries
  // (`tags && ARRAY[...]`). The weakness-profile aggregator runs in
  // application code over a class roster's wrong-answer rows, so the
  // hot path is Question rows JOINed via AnswerScript → PaperQuestion
  // and not a tag-by-tag scan. Add a GIN extension index later if the
  // bank grows past ~50k Questions and the join becomes slow.

  @@index([subjectId, componentId, status])
  @@index([primaryTopicId])
  @@index([complianceStatus, status])
  @@index([provenanceTag])
}

model QuestionTopic {
  questionId String
  topicId    String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([questionId, topicId])
}

model QuestionAsset {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  assetType  String // image | svg
  storageUrl String
  altText    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  // AI provenance — null for teacher-uploaded assets, populated when the
  // image was generated by an AI image model (model id stored in aiModel).
  // aiPrompt is the full prompt sent to the model so a teacher can see
  // why the image looks the way it does and re-generate with tweaks.
  aiGenerated Boolean @default(false)
  aiModel     String?
  aiPrompt    String?
  aiCostUsd   Float?
  aiCreatedBy String?
}

model QuestionVersion {
  id            String   @id @default(cuid())
  questionId    String
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  versionNumber Int
  snapshot      Json
  changedById   String
  // B4: Restrict — version-history actor stays referenceable.
  changedBy     User     @relation(fields: [changedById], references: [id], onDelete: Restrict)
  changedAt     DateTime @default(now())
  changeNote    String?

  @@unique([questionId, versionNumber])
}

// ============================================================
// Paper Templates
// ============================================================
model PaperTemplate {
  id              String             @id @default(cuid())
  ownerId         String
  // B4: Restrict — template authorship audited; admin must reassign first.
  owner           User               @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  name            String
  subjectId       String
  subject         Subject            @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  componentId     String?
  component       SyllabusComponent? @relation(fields: [componentId], references: [id], onDelete: SetNull)
  durationMin     Int
  totalMarks      Int
  config          Json // { questionMix, difficultyDist, topicFilter, excludeRecentDays }
  isSchoolDefault Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  papers          Paper[]
}

// ============================================================
// Generated Papers
// ============================================================
enum PaperStatus {
  draft
  published
  archived
}

model Paper {
  id               String             @id @default(cuid())
  ownerId          String
  // B4: Restrict — owner audit; deleting a teacher must not orphan papers.
  owner            User               @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  templateId       String?
  // B4: SetNull — template can be deleted independently; paper keeps going.
  template         PaperTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  name             String
  classLabel       String?
  subjectId        String
  subject          Subject            @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  componentId      String?
  component        SyllabusComponent? @relation(fields: [componentId], references: [id], onDelete: SetNull)
  examDate         DateTime?
  durationMin      Int
  totalMarksTarget Int
  totalMarksActual Int
  status           PaperStatus        @default(draft)
  generatedSeed    Int
  config           Json // snapshot of generation config

  // ── AI QA review (morning-quiz IELTS papers) ──────────────────────
  // Set by MorningQuizQaService after every passage_pick / quick-paper
  // generation. verdict gates whether students see the paper:
  //   pass         → goes live untouched
  //   needs_review → live but flagged for teacher (yellow badge in UI)
  //   reject       → blocked, automatic regenerate kicks in (max 2 retries)
  //   pending      → review still in flight (or never ran)
  // Issues/summary preserved for teacher dashboard drilldown.
  qaReviewVerdict   String?   @default("pending")
  qaReviewSummary   String?
  qaReviewIssues    Json?
  qaReviewedAt      DateTime?
  qaReviewModel     String?
  qaReviewTokens    Int?
  qaReviewCostUsd   Float?
  qaReviewRetries   Int       @default(0)
  // Teacher decision once a 'needs_review' paper has been triaged:
  //   approved | rejected | edited (with manual edits) | null=untouched
  qaTeacherAction   String?
  qaTeacherActionAt DateTime?
  qaTeacherActionBy String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  // R14 — Feature 6: paper soft-delete. Listing endpoints filter
  // `archivedAt IS NULL`; archived papers remain reachable for audit /
  // re-issue but stop appearing in normal teacher browse views.
  archivedAt DateTime?

  questions       PaperQuestion[]
  versions        PaperVersion[]
  usageLogs       QuestionUsageLog[]
  assignments     PaperAssignment[]
  // Path-B back-relations
  watermarkTokens WatermarkToken[]
  // Morning quiz back-relations
  shuffleMaps     QuestionShuffleMap[]

  // Indexes added round-7 D3 — teacher QA-review queue scans by verdict
  // (`needs_review` / `reject` filter) and the cron picks `status=archived`
  // candidates by ownerId. Neither query had an index until now.
  @@index([qaReviewVerdict, qaTeacherAction])
  @@index([ownerId, status])
}

model PaperQuestion {
  id              String   @id @default(cuid())
  paperId         String
  paper           Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  questionId      String
  // B4: Restrict — a Question that's referenced by a Paper cannot be
  // dropped silently; deleting a Question requires the admin to first
  // detach it from every Paper using it (snapshotContent is preserved
  // on PaperQuestion already, so the paper survives the detach).
  question        Question @relation(fields: [questionId], references: [id], onDelete: Restrict)
  sortOrder       Int
  snapshotContent Json // taken at generation time
  snapshotAnswer  Json
  snapshotOptions Json?
  overrideContent Json? // teacher edits within this paper, doesn't touch master
  overrideAnswer  Json?
  marks           Int

  scripts       AnswerScript[]
  // Path-B back-relations
  tutorSessions TutorSession[]
  // R14 — Feature 10: per-question appeals.
  appeals       GradeAppeal[]
  // R14 — Feature 15: retraction (1:1 optional).
  retraction    QuestionRetraction?

  @@index([paperId, sortOrder])
}

model PaperVersion {
  id            String   @id @default(cuid())
  paperId       String
  paper         Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  versionNumber Int
  snapshot      Json
  changedById   String
  // B4: Restrict — paper-version author audit.
  changedBy     User     @relation(fields: [changedById], references: [id], onDelete: Restrict)
  changedAt     DateTime @default(now())
  changeNote    String?

  @@unique([paperId, versionNumber])
}

// ============================================================
// Audit / Usage
// ============================================================
model QuestionUsageLog {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  paperId    String
  paper      Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  classLabel String?
  usedAt     DateTime @default(now())

  @@index([questionId, usedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  action     String
  entityType String
  entityId   String
  diff       Json?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

// ============================================================
// Phase 2 — Ingestion + Compliance
// ============================================================

enum RepoType {
  with_pdfs // GitHub repos that contain raw PDFs
  notes_only // study notes / markdown — usually skipped
  downloader_script // scripts that scrape exam-board CDNs — never used directly
  topic_page // github.com/topics/* — discovery only
  official // exam-board source via school's licensed account
  school_upload // teacher / admin manual upload
  ai_generator // AI-produced original questions
}

enum SyncStatus {
  idle
  running
  ok
  failed
}

enum ComplianceStatus {
  pending_review // default for new sources / files / items
  approved_internal // school-authored, AI-generated, or licensed
  restricted_internal // licensed past papers — internal-only, audit required
  blocked // takedown / unlicensed — DB-level filter excludes
  expired // licence lapsed — same effect as blocked
}

enum AllowedUsage {
  free_use // school owns / created
  internal_classroom_only // licensed past papers, internal only
  metadata_reference_only // never render full content, only the source ref
  none // not yet cleared
}

enum RetentionPolicy {
  keep_indefinite
  delete_after_review
  delete_when_blocked
  school_license_term
}

enum FileKind {
  question_paper
  mark_scheme
  examiner_report
  insert
  syllabus_doc
  other
}

enum ProcessStatus {
  pending
  processing
  processed
  failed
  skipped
}

enum ReviewStatus {
  pending_review
  needs_human_review
  approved
  rejected
  on_hold
}

enum AssetKind {
  figure
  diagram
  graph
  chemical_structure
  equation_image
  table
  other
}

enum TagSource {
  ai
  filename
  heuristic
  teacher
}

enum QuestionItemSource {
  past_paper
  ai_generated
  manual
}

model SourceRepository {
  id                String           @id @default(cuid())
  url               String           @unique
  repoType          RepoType
  licenseDetected   String?
  licenseTextUrl    String?
  examBoardHint     String?
  lastSyncedAt      DateTime?
  syncStatus        SyncStatus       @default(idle)
  syncError         String?
  // Default deny: a new repo is parked in pending_review until an admin
  // explicitly upgrades its compliance_status. The sync worker will refuse
  // to clone repos that are still pending or blocked.
  complianceStatus  ComplianceStatus @default(pending_review)
  // Whitelist of CIE syllabus codes (e.g. ["9709","9702"]) the sync worker
  // will keep when ingesting PDFs from this repo. Empty = accept everything
  // the filename-parser can identify. Files with no parseable syllabusCode
  // are skipped when the list is non-empty.
  syllabusAllowlist String[]         @default([])
  // Whitelist of exam years (e.g. [2019, 2020]). Same default-empty rule
  // as syllabusAllowlist — empty list = no year gate. Files whose
  // filename-parsed examYear isn't in the list are skipped.
  yearAllowlist     Int[]            @default([])
  copyrightOwner    String?
  allowedUsage      AllowedUsage     @default(none)
  retentionPolicy   RetentionPolicy  @default(delete_when_blocked)
  notesForTeachers  String?
  addedById         String
  addedBy           User             @relation("RepoAddedBy", fields: [addedById], references: [id])
  addedAt           DateTime         @default(now())
  blockedReason     String?
  blockedAt         DateTime?
  files             SourceFile[]

  @@index([complianceStatus])
  @@index([syncStatus])
}

model SourceFile {
  id               String           @id @default(cuid())
  repoId           String
  repo             SourceRepository @relation(fields: [repoId], references: [id], onDelete: Cascade)
  rawFilename      String
  storagePath      String // s3://... or local path
  sha256           String           @unique
  fileSizeBytes    Int
  fileKind         FileKind         @default(other)
  syllabusCode     String? // e.g. 9702
  examYear         Int?
  examSeason       String? // m / s / w
  paperVariant     String? // 22
  paperNumber      String? // qp / ms / er / in
  parsedFromName   Json?
  ingestedAt       DateTime         @default(now())
  processStatus    ProcessStatus    @default(pending)
  processError     String?
  // Inherits from repo by default but stays mutable so individual files
  // can be blocked without blocking the whole source.
  complianceStatus ComplianceStatus @default(pending_review)

  pages         PdfPage[]
  questionItems QuestionItem[]

  @@index([repoId, fileKind])
  @@index([syllabusCode, examYear, examSeason])
  @@index([complianceStatus, processStatus])
}

model PdfPage {
  id            String     @id @default(cuid())
  sourceFileId  String
  sourceFile    SourceFile @relation(fields: [sourceFileId], references: [id], onDelete: Cascade)
  pageNo        Int
  rawText       String?
  layoutJson    Json?
  imageUrl      String?
  // Inline PNG bytes so the rendered page survives across container
  // restarts and can be replicated via pg_dump. Without this, the API
  // could only serve from RENDER_STORAGE_PATH on the local filesystem,
  // which is ephemeral on most container hosts. The page-image controller
  // serves these bytes when present and falls back to the disk PNG when
  // the column is null (so legacy rows keep working until backfilled).
  imageBytes    Bytes?
  ocrUsed       Boolean    @default(false)
  ocrConfidence Float?

  @@unique([sourceFileId, pageNo])
}

model QuestionItem {
  id           String             @id @default(cuid())
  source       QuestionItemSource @default(past_paper)
  sourceFileId String?
  // B4: SetNull — when a SourceFile is dropped, the QuestionItem mirror
  // can keep its extracted text + AI metadata (the paper trail of where
  // it came from is in audit log); avoids orphan-cascade nuking review work.
  sourceFile   SourceFile?        @relation(fields: [sourceFileId], references: [id], onDelete: SetNull)
  // Once approved, a mirrored Question row is created and linked here.
  // Until then, generators cannot see this item (Question is the consumer).
  questionId   String?            @unique
  question     Question?          @relation("QuestionItemMirror", fields: [questionId], references: [id])

  // AI-generation provenance — populated only when source = ai_generated.
  aiModel       String?
  aiPrompt      String?
  aiCostUsd     Float?
  aiCreatedById String?

  pageStart        Int?
  pageEnd          Int?
  cropBboxJson     Json?
  cropImageUrl     String?
  rawExtractedText String?
  extractedLatex   String?
  questionNumber   String?

  // AI-suggested metadata — never auto-applied; teachers confirm.
  suggestedSubjectCode String?
  suggestedTopicCode   String?
  suggestedType        QuestionType?
  suggestedMarks       Int?
  suggestedDifficulty  Int?
  suggestedMetadata    Json?

  confidenceSplit Float?
  confidenceMarks Float?
  confidenceMs    Float?
  confidenceTopic Float?

  reviewStatus ReviewStatus @default(pending_review)
  reviewedById String?
  // B4: SetNull — reviewer can be deactivated; review still attributable
  // by audit log + reviewedAt timestamp.
  reviewedBy   User?        @relation("QuestionItemReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  reviewNotes  String?

  complianceStatus ComplianceStatus @default(pending_review)

  parts           QuestionPart[]
  ingestedAssets  IngestedAsset[]
  markSchemeItems MarkSchemeItem[]
  topicMap        QuestionItemTopic[]
  reviews         TeacherReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewStatus, complianceStatus])
  @@index([sourceFileId])
}

model QuestionPart {
  id             String         @id @default(cuid())
  questionItemId String
  questionItem   QuestionItem   @relation(fields: [questionItemId], references: [id], onDelete: Cascade)
  partLabel      String
  parentPartId   String?
  parentPart     QuestionPart?  @relation("PartChild", fields: [parentPartId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children       QuestionPart[] @relation("PartChild")
  marks          Int
  text           String
  latexText      String?
  cropBboxJson   Json?
  cropImageUrl   String?
  sortOrder      Int            @default(0)
}

model IngestedAsset {
  id             String       @id @default(cuid())
  questionItemId String
  questionItem   QuestionItem @relation(fields: [questionItemId], references: [id], onDelete: Cascade)
  kind           AssetKind
  imageUrl       String
  pageNo         Int?
  bboxJson       Json?
  altText        String?
  ocrText        String?
  sortOrder      Int          @default(0)
}

model MarkSchemeItem {
  id               String       @id @default(cuid())
  questionItemId   String
  questionItem     QuestionItem @relation(fields: [questionItemId], references: [id], onDelete: Cascade)
  partLabel        String?
  pointText        String
  marks            Int
  notesForExaminer String?
  cropImageUrl     String?
  matchConfidence  Float?
  sortOrder        Int          @default(0)
}

model QuestionItemTopic {
  questionItemId String
  questionItem   QuestionItem @relation(fields: [questionItemId], references: [id], onDelete: Cascade)
  topicId        String
  topic          Topic        @relation("ItemTopics", fields: [topicId], references: [id], onDelete: Cascade)
  confidence     Float
  taggedBy       TagSource    @default(ai)

  @@id([questionItemId, topicId])
}

model TeacherReview {
  id             String       @id @default(cuid())
  questionItemId String
  questionItem   QuestionItem @relation(fields: [questionItemId], references: [id], onDelete: Cascade)
  reviewerId     String
  reviewer       User         @relation("ReviewActor", fields: [reviewerId], references: [id])
  action         String // approve | reject | edit_metadata | flag_copyright | link_mark_scheme | remap_topic
  reasonCode     String?
  notes          String?
  metadataDiff   Json?
  createdAt      DateTime     @default(now())

  @@index([questionItemId, createdAt])
}

// ============================================================
// Block B1 — Marker workflow (PATH-B FRAGMENT, NOT YET MERGED)
// ============================================================
//
// This file lives outside `schema.prisma` because B1..B10 are being built in
// parallel. Each path-B agent writes its additions here so the integrator can
// concatenate them into the main schema in one controlled merge.
//
// SCOPE FOR B1:
//   - Add a `MarkerAssignment` model representing a marker's *claim* on a
//     submitted StudentSubmission. The claim is the row-level lock that
//     prevents two markers from grading the same submission concurrently.
//
// NOTE — fields we'd LIKE to add but cannot, because they live on models
// owned by other parts of the schema. These are documented in
// `apps/api/src/marker/MERGE_INSTRUCTIONS.md` for the integrator:
//   - StudentSubmission needs a back-relation `markerAssignments
//     MarkerAssignment[]` so Prisma compiles the FK below.
//   - User needs a back-relation `markerAssignments MarkerAssignment[]`
//     (named relation "MarkerAssignmentMarker") so the marker-FK below
//     compiles. The MarkerAssignment.marker side names the relation.
//
// AnswerScript already carries everything we need for the per-script
// score (`awardedMarks`, `markerComment`, `markedById`, `markedAt`), so
// no schema changes are required for the score itself.

model MarkerAssignment {
  id           String            @id @default(cuid())
  submissionId String            @unique // one active claim per submission
  // Cascade so deleting a submission also drops its claim row. We don't
  // expect submissions to be deleted in practice but in the test harness
  // we wipe rosters between runs and want a clean teardown.
  submission   StudentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  markerId     String
  marker       User              @relation("MarkerAssignmentMarker", fields: [markerId], references: [id])
  claimedAt    DateTime          @default(now())
  releasedAt   DateTime?
  // 'active' while marker is grading; 'released' after they hand it back
  // (we keep the row for an audit trail, then upsert on next claim).
  status       String            @default("active")

  @@index([markerId, status])
  @@index([submissionId, status])
}

// ============================================================
// Block B3 — AI question quality feedback loop (PATH-B FRAGMENT, NOT YET MERGED)
// ============================================================
//
// SCOPE FOR B3:
//   Capture quality signals about AI-generated (and human-curated) questions
//   so future AI generation prompts can be weighted by what teachers and
//   students actually do with the output. Two signal sources:
//     - Teacher review actions (approve / reject / post-approval edit)
//     - Student answer outcomes (correct / wrong / skipped)
//   Aggregated into a per-question score and a per-topic leaderboard so the
//   AI generator can fold "topic X needs harder questions" hints into the
//   next prompt.
//
// NOTES on cross-model relations we'd LIKE to add but cannot from a fragment:
//   - Question needs a back-relation `qualityFeedbackSignals
//     QuestionQualitySignal[]` so this FK compiles. The integrator must add
//     it to the Question model in `schema.prisma` (see MERGE_INSTRUCTIONS).
//   - We deliberately do NOT add a User FK on `recordedById`. Recording the
//     user as a free-form String keeps the model decoupled from auth and
//     lets us insert system-emitted signals (auto-grade) without a User row.

enum QuestionQualitySignalType {
  approved // teacher hit "approve" on a review item / AI-gen output
  rejected // teacher hit "reject"
  edited // teacher edited content/marks/answer AFTER approval
  answered_correct // student got the question right (MCQ auto, or marker awarded full marks)
  answered_wrong // student got it wrong (MCQ auto, or marker awarded < 50% of full marks)
  skipped // student left it blank in a final-submitted submission
}

model QuestionQualitySignal {
  id           String                    @id @default(cuid())
  questionId   String
  // No back-relation declared from this side until the integrator adds the
  // matching `qualityFeedbackSignals QuestionQualitySignal[]` array on
  // Question. Until then the FK is enforced by Prisma alone.
  question     Question                  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  signalType   QuestionQualitySignalType
  // Per-signal weight. Defaults are applied in the service layer
  //   approved          => +1.0
  //   rejected          => -2.0   (reject is a stronger signal than approve)
  //   edited            => -0.5   (edit means the AI got close but not right)
  //   answered_correct  => +0.2   (one student datapoint = small weight)
  //   answered_wrong    => -0.2
  //   skipped           => -0.1
  // Stored on the row so we can re-weight historical signals later without
  // having to encode a "version" of the weighting function.
  weight       Float                     @default(0)
  // Free-form context: { subtopicCode?, awardedMarks?, marks?, reason?, editedFields? }
  meta         Json?
  // Optional actor — stored as a plain string so system-emitted rows
  // (auto-grade, marker finalize) don't need a real User row.
  recordedById String?
  recordedAt   DateTime                  @default(now())

  @@index([questionId, recordedAt])
  @@index([signalType, recordedAt])
}

// ============================================================
// Block B7 — Multi-version paper variants + WeChat notifications
// (PATH-B FRAGMENT, NOT YET MERGED)
// ============================================================
//
// This file lives outside `schema.prisma` because B1..B10 are being built
// in parallel. Each path-B agent writes its additions here so the
// integrator can concatenate them into the main schema in one controlled
// merge.
//
// SCOPE FOR B7:
//   1. PaperVariantAssignment — anti-cheat. One row per (assignment,
//      student). Stores a deterministic shuffle seed plus the resolved
//      `questionOrder` and `optionShuffles` so a student who refreshes
//      mid-exam sees the same form. Adjacent students get different
//      seeds so their forms differ.
//   2. NotificationConfig — admin-managed wiring of an event (paper
//      assigned / marked / low-score) to a channel (wechat_work /
//      dingtalk / email). `target` is JSON because each channel needs
//      different shape (webhook URL, mailing list, etc.).
//   3. NotificationLog — append-only audit of every fired notification.
//      Stores payload + httpStatus + error so admins can debug a
//      misconfigured webhook without re-firing.
//
// NOTE — back-relations we'd LIKE on existing models but cannot add
// here (the integrator will add them when concatenating into
// schema.prisma):
//   - PaperAssignment needs `variantAssignments PaperVariantAssignment[]`
//     so Prisma compiles the FK on PaperVariantAssignment.assignment.
//   - User needs `paperVariants PaperVariantAssignment[]` (named
//     relation "PaperVariantStudent") so Prisma compiles the FK on
//     PaperVariantAssignment.student.
//   - Neither NotificationConfig nor NotificationLog references any
//     existing model, so no other back-relations are required.
//
// See `apps/api/src/paper-variants/MERGE_INSTRUCTIONS.md` for the full
// merge plan and the two AppModule registration lines.

enum NotificationEvent {
  paper_assigned
  paper_marked
  low_score
  // Round-4 morning-quiz add-ons (already used by absence-alert + cron)
  morning_quiz_cron_failed
  consecutive_absent
  // F1: twice-daily teacher digest (08:30 + 18:30 server-local)
  teacher_daily_digest
  // F2: Sunday-night batch-generation review-gate notification (22:00)
  morning_quiz_review_gate
  // F2: paper auto-released past Monday 06:30 because teacher didn't act
  morning_quiz_auto_released
}

enum NotificationChannel {
  wechat_work
  dingtalk
  email
}

model PaperVariantAssignment {
  id             String          @id @default(cuid())
  // FK to PaperAssignment. Cascade-delete: if the underlying assignment
  // is dropped (e.g. test harness wipe) we don't want orphan variant
  // rows pointing at a missing assignment.
  assignmentId   String
  assignment     PaperAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  // FK to User (the student). Not cascading to keep the audit trail if
  // a student row is ever soft-deleted; in practice we use restrict.
  studentId      String
  student        User            @relation("PaperVariantStudent", fields: [studentId], references: [id])
  // Deterministic shuffle seed. Same (assignmentId, studentId) → same
  // seed → same shuffle even after a refresh / reconnect.
  seed           Int
  // Resolved display order: array of paperQuestionId strings in the
  // order this student should see them. Stored rather than recomputed
  // on each request so the take-paper UI doesn't need to know the
  // shuffle algorithm.
  questionOrder  Json
  // Per-paperQuestion option-letter mapping. Shape:
  //   { "<paperQuestionId>": { "A": "C", "B": "A", "C": "D", "D": "B" } }
  // Read as: original option key A is shown to this student under
  // letter C. The take-paper UI relabels options at render time.
  // Empty {} when mode is 'shuffle_questions' only.
  optionShuffles Json
  generatedAt    DateTime        @default(now())

  // One variant row per (assignment, student). Re-running the
  // generate-for-class endpoint is idempotent because of this.
  @@unique([assignmentId, studentId])
  @@index([assignmentId])
}

model NotificationConfig {
  id        String              @id @default(cuid())
  event     NotificationEvent
  channel   NotificationChannel
  // Channel-specific routing. For wechat_work / dingtalk this holds
  //   { "webhookUrl": "https://..." }
  // For email this holds { "to": ["a@b.com", ...], "subjectPrefix": "..." }
  // Use JSON so we can evolve the shape without a migration each time.
  // STUB BEHAVIOUR: if webhookUrl starts with "noop://" the dispatcher
  // logs to NotificationLog without making an HTTP call. This lets
  // admins create configs before the real webhook URL is provisioned.
  target    Json
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([event, channel, enabled])
}

model NotificationLog {
  id         String              @id @default(cuid())
  // Logged on every send attempt — even when the matching config is
  // disabled (then we record a synthetic httpStatus 0 + error
  // "config disabled" so the operator can see why nothing fired).
  configId   String?
  event      NotificationEvent
  channel    NotificationChannel
  payload    Json
  // 0 for noop:// stubs, 200..599 for real HTTP responses, 0 for
  // network errors (error column carries the message).
  httpStatus Int
  error      String?
  sentAt     DateTime            @default(now())

  @@index([event, sentAt])
  @@index([configId, sentAt])
}

// ============================================================
// Block B8 — Code Grader (PATH-B FRAGMENT, NOT YET MERGED)
// ============================================================
//
// This file lives outside `schema.prisma` because B1..B10 are being built in
// parallel. Each path-B agent writes its additions here so the integrator can
// concatenate them into the main schema in one controlled merge.
//
// SCOPE FOR B8:
//   - Add `CodeQuestionTestCase` — test cases attached to a Question of
//     questionType='structured' (or a future 'code' type) for CS coding
//     items (Cambridge 9608/9618 etc.). Each test case feeds judge0 with
//     `stdin`, expects `expectedStdout`, and is worth `marksPerCase` if
//     it passes. `hidden=true` test cases are not shown to students before
//     submission (only revealed after final submit, matching most online
//     judges).
//   - Add `CodeSubmissionResult` — one row per AnswerScript that was
//     code-judged. Stores last run aggregate so the marker / dashboard
//     doesn't re-run judge0. `awardedMarks` here is fed back into
//     AnswerScript.awardedMarks at submit time so the existing scoring
//     pipeline stays single-source-of-truth.
//
// NOTE — fields we'd LIKE to add but cannot, because they live on models
// owned by other parts of the schema. These are documented in
// `apps/api/src/codegrader/MERGE_INSTRUCTIONS.md` for the integrator:
//   - Question needs a back-relation `codeTestCases CodeQuestionTestCase[]`
//     so Prisma compiles the FK below.
//   - AnswerScript needs a back-relation `codeResult CodeSubmissionResult?`
//     so the @unique-on-answerScriptId one-to-one relation compiles.

model CodeQuestionTestCase {
  id             String   @id @default(cuid())
  questionId     String
  // Cascade so deleting a question wipes its test cases — they're useless
  // without the parent question and we don't want orphan rows polluting
  // the bank.
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  // Free-form stdin fed to the student's program. Empty string is fine
  // for "no input" cases (e.g. print-a-constant programs).
  stdin          String   @default("")
  // Expected stdout — string-equality match after trimming trailing
  // whitespace (judge runner normalises). Multi-line is supported.
  expectedStdout String
  // Marks awarded if the case passes. Sum across cases = the codeable
  // portion of the question's marks. Service layer validates that the
  // sum doesn't exceed Question.marks at the time of test-case create.
  marksPerCase   Int      @default(1)
  // If true, students don't see this case before submitting (sample vs
  // hidden split, classic online-judge style). Teachers always see all.
  hidden         Boolean  @default(false)
  // Optional human label so the teacher UI can show "edge case: empty
  // input" etc.
  label          String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([questionId, sortOrder])
}

model CodeSubmissionResult {
  id             String       @id @default(cuid())
  // One result per AnswerScript — re-judging upserts in place so we
  // never drift from the script.awardedMarks figure shown to students.
  answerScriptId String       @unique
  answerScript   AnswerScript @relation(fields: [answerScriptId], references: [id], onDelete: Cascade)
  // Source language slug used to pick the judge0 language id at run
  // time. We keep it as String (not enum) so adding python/c++/java
  // doesn't need a migration.
  language       String
  // Last source code we judged — useful for the marker UI to show what
  // was actually run (the AnswerScript.textAnswer is what the student
  // saved; codegrader copies it here at judge time so a re-judge after
  // the student keeps editing still tells you what *this* run saw).
  sourceCode     String
  // Aggregate stdout/stderr from the LAST test case (or a join across
  // all cases, runner's choice). Truncated to 8KB by service to keep
  // the row small.
  stdout         String?
  stderr         String?
  // Total runtime across all cases in milliseconds (sum, not max).
  runtimeMs      Int          @default(0)
  passedCases    Int          @default(0)
  totalCases     Int          @default(0)
  // Sum of marksPerCase × passed. Float because partial credit / future
  // weighting could push it off integers. Mirrored to AnswerScript
  // .awardedMarks at the same time (single source of truth lives on
  // AnswerScript so the marker queue can ignore this table).
  awardedMarks   Float        @default(0)
  // Free-form metadata: { stub: true } when running without a real
  // judge0, judge0 token list when real, error info when run failed.
  meta           Json?
  judgedAt       DateTime     @default(now()) @updatedAt

  @@index([judgedAt])
}

// ============================================================
// Block B9 — AI tutor chat for students (PATH-B FRAGMENT, NOT YET MERGED)
// ============================================================
//
// SCOPE FOR B9:
//   After a student submits a paper, they can open a tutor chat about a
//   specific paperQuestion they got wrong. The tutor (Claude) is given the
//   question stem + the student's submitted answer + the markScheme as a
//   SYSTEM-ONLY context (the markScheme MUST never appear verbatim in the
//   reply that goes back to the student — see ai-tutor.service.ts).
//
//   We track every assistant message's cost in USD on TutorMessage.costUsd
//   and roll it up to TutorSession.totalCostUsd. A per-student daily cap is
//   enforced in the service layer (TUTOR_DAILY_USD_PER_STUDENT_CAP, default
//   $0.50) so a single student can never burn unbounded API spend.
//
// NOTES on cross-model relations the integrator must add:
//   - User needs a back-relation `tutorSessions TutorSession[]` so the FK
//     `TutorSession.studentId -> User.id` compiles. See MERGE_INSTRUCTIONS.
//   - StudentSubmission needs an OPTIONAL back-relation
//     `tutorSessions TutorSession[]` so the optional FK
//     `TutorSession.submissionId -> StudentSubmission.id` compiles.
//   - PaperQuestion needs an OPTIONAL back-relation
//     `tutorSessions TutorSession[]` so the optional FK
//     `TutorSession.paperQuestionId -> PaperQuestion.id` compiles.
//
//   We deliberately keep submissionId / paperQuestionId OPTIONAL: a student
//   may want to chat about a topic without binding to a specific submission
//   row, and we don't want to lose the session if the underlying submission
//   gets deleted. (The chat history is the durable record.)
//
//   Both FKs use `onDelete: SetNull` so deleting a submission / paperQuestion
//   doesn't cascade-wipe the chat audit trail (cost-audit data must persist).

model TutorSession {
  id        String @id @default(cuid())
  // The student who owns this session. Required: every session is bound to
  // exactly one student so the per-student daily cap can be summed.
  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  // Optional: the submission this chat is "about". Nullable so the chat
  // outlives a deleted submission.
  submissionId String?
  submission   StudentSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  // Optional: the specific paperQuestion the student wants to discuss. The
  // tutor uses this to fetch question stem + markScheme server-side.
  paperQuestionId String?
  paperQuestion   PaperQuestion? @relation(fields: [paperQuestionId], references: [id], onDelete: SetNull)

  startedAt DateTime  @default(now())
  endedAt   DateTime?

  // Sum of TutorMessage.costUsd across this session's assistant messages.
  // Updated atomically by the service after each Claude call.
  totalCostUsd Float @default(0)

  messages TutorMessage[]

  @@index([studentId, startedAt])
  @@index([submissionId])
  @@index([paperQuestionId])
}

enum TutorRole {
  student
  assistant
}

model TutorMessage {
  id        String       @id @default(cuid())
  sessionId String
  session   TutorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      TutorRole
  // Free-form chat content. For 'student' rows this is exactly what the
  // student typed; for 'assistant' rows this is what Claude returned (and
  // MUST NOT contain the markScheme verbatim — service-layer prompt
  // forbids it and the response is not post-processed to add answer-key
  // fields).
  content   String
  createdAt DateTime     @default(now())
  // Set only on assistant messages. Computed from the Anthropic
  // resp.usage.input_tokens / output_tokens at the Sonnet rates declared
  // in ai-tutor.service.ts. NULL for student rows.
  costUsd   Float?

  @@index([sessionId, createdAt])
}

// ============================================================
// Block B10 — Per-student PDF watermark tokens (PATH-B FRAGMENT, NOT YET MERGED)
// ============================================================
//
// This file lives outside `schema.prisma` because B1..B10 are being built in
// parallel. Each path-B agent writes its additions here so the integrator can
// concatenate them into the main schema in one controlled merge.
//
// SCOPE FOR B10:
//   - Add a `WatermarkToken` model that uniquely identifies one (paper,
//     student) pair — used to overlay an opaque, traceable mark on a PDF
//     copy of a paper that's downloaded for that specific student.
//   - If a watermarked paper later appears online, the visible token in the
//     overlay can be looked up via /watermark/lookup to identify which
//     student's copy leaked.
//
// Properties of the token:
//   - `token` is an 8-char base32 string (Crockford alphabet) generated in
//     the service layer. Short enough to be readable on a printed page,
//     long enough to be effectively non-guessable for the small population
//     of students per school (32^8 ≈ 1.1e12).
//   - `@unique` so a leaked token resolves to exactly one record.
//   - `revokedAt` lets an admin invalidate a leaked download URL (future
//     downloads via that URL return 410). The token row itself is NEVER
//     deleted — we want to keep the forensic trail.
//   - `assignmentId` is OPTIONAL because watermarking can be requested
//     for a paper the student isn't yet assigned (e.g. preview print
//     for a teacher-led mock). When present we prefer it for context.
//
// NOTES on cross-model relations we'd LIKE to add but cannot from a fragment:
//   - Paper needs a back-relation `watermarkTokens WatermarkToken[]` so this
//     FK compiles. The integrator must add it to the Paper model in
//     `schema.prisma` (see MERGE_INSTRUCTIONS).
//   - User needs a back-relation `watermarkTokens WatermarkToken[]` (named
//     relation "WatermarkTokenStudent") so the student-FK compiles.
//   - PaperAssignment needs an OPTIONAL back-relation
//     `watermarkTokens WatermarkToken[]` for the assignment FK.
//   - We deliberately do NOT cascade delete from Paper/User: if a student
//     is removed we still want to keep the WatermarkToken row for forensic
//     replay. Set the FK with onDelete: SetNull-style guarantees at the
//     application layer instead (see watermark.service.ts).

model WatermarkToken {
  id           String           @id @default(cuid())
  paperId      String
  paper        Paper            @relation(fields: [paperId], references: [id])
  studentId    String
  student      User             @relation("WatermarkTokenStudent", fields: [studentId], references: [id])
  // Optional — present when the watermark was issued in the context of a
  // specific PaperAssignment (so we can scope leaks to a class). Null when
  // the token was minted ad-hoc (e.g. teacher print preview).
  assignmentId String?
  assignment   PaperAssignment? @relation(fields: [assignmentId], references: [id])

  // 8-char Crockford-base32 string — the visible mark. Globally unique so a
  // single leaked token resolves to exactly one (paper, student) pair.
  token String @unique

  createdAt DateTime  @default(now())
  // Set when an admin revokes the token — future GET /watermark/download?token=X
  // returns 410 Gone. The row itself is never deleted (forensic trail).
  revokedAt DateTime?

  // Lookup helpers — get-or-create by (paperId, studentId) is the hot path
  // when we mint the URL, and a lookup by token is the forensic path.
  @@unique([paperId, studentId])
  @@index([studentId])
}

// ============================================================
// Morning Attendance + Quiz (feature/morning-attendance-quiz)
// See DESIGN-MORNING-QUIZ.md for full design
// ============================================================
enum MorningQuizStatus {
  scheduled
  active
  locked
  cancelled
}

enum AttendanceStatus {
  on_time
  late
  absent
}

enum AttendanceSource {
  qr_scan
  manual_correction
}

enum EnglishLevel {
  ielts_authentic // Cambridge IELTS authentic past papers (passage_pick)
  ielts_simplified // simplified-IELTS for OLEVEL+ students (AI-generated, lower-vocab)
  olevel // CIE 1123 OLEVEL English (AI-generated)
}

model MorningQuizSession {
  id                String            @id @default(cuid())
  date              DateTime          @db.Date
  classId           String
  class             Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  paperAssignmentId String            @unique
  paperAssignment   PaperAssignment   @relation(fields: [paperAssignmentId], references: [id], onDelete: Cascade)
  attendanceStart   DateTime
  attendanceEnd     DateTime
  lateCutoff        DateTime
  quizStart         DateTime
  quizEnd           DateTime
  qrSecret          String
  qrRotationSeconds Int               @default(15)
  status            MorningQuizStatus @default(scheduled)
  scheduledById     String
  scheduledBy       User              @relation("MorningQuizScheduledBy", fields: [scheduledById], references: [id])
  createdAt         DateTime          @default(now())

  // R10 — multi-level: a class can run sessions in several difficulty
  // bands per day. The session's level is denormalised here so cron /
  // scheduling don't have to walk through paperAssignment + ClassEnglishLevel
  // to figure out which band an in-flight session belongs to.
  level EnglishLevel @default(ielts_authentic)

  attendances Attendance[]

  @@unique([date, classId, level])
  @@index([date, status])
  // Round-7 H15 (agent-3 D7): MorningQuiz schedule reads use
  // `WHERE classId = ? AND date >= ?` to find a class's upcoming
  // sessions; planner needs a (classId, date) index since the unique
  // is keyed (date, classId) — wrong column order for that filter.
  @@index([classId, date])
}

model Attendance {
  id            String             @id @default(cuid())
  sessionId     String
  session       MorningQuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId     String
  student       User               @relation("AttendanceStudent", fields: [studentId], references: [id])
  status        AttendanceStatus
  scanTime      DateTime?
  sourceIp      String?
  // localStorage UUID minted by the scanning device on first visit, sent
  // with every subsequent scan. Used to block same-device-multi-student
  // attendance fraud (one phone signing in as 30 students by re-picking
  // names). Null when source=manual_correction.
  deviceUuid    String?
  // Browser User-Agent at scan time, retained for forensics if a deviceUuid
  // conflict is disputed. Not used for enforcement.
  userAgent     String?
  source        AttendanceSource
  correctedById String?
  correctedBy   User?              @relation("AttendanceCorrectedBy", fields: [correctedById], references: [id])
  correctedNote String?
  submissionId  String?            @unique
  submission    StudentSubmission? @relation(fields: [submissionId], references: [id])
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([sessionId, studentId])
  @@index([studentId, status])
  @@index([sessionId, deviceUuid])
}

// R10 — class-level enrolment in difficulty bands. Was 1:1 (one class
// → one level), now 1:N: a class can run morning quizzes in multiple
// bands the same day. Each (class, level) pair shows up as its own
// row; batch-generate iterates over them.
model ClassEnglishLevel {
  id            String       @id @default(cuid())
  classId       String
  class         Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  level         EnglishLevel
  effectiveFrom DateTime
  createdAt     DateTime     @default(now())

  @@unique([classId, level])
  @@index([classId])
}

model QuestionShuffleMap {
  id            String   @id @default(cuid())
  studentId     String
  student       User     @relation("ShuffleMapStudent", fields: [studentId], references: [id])
  paperId       String
  paper         Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  seed          String
  // Permutation array: index = display position, value = original question index.
  questionOrder Int[]
  // Map keyed by question id → array permutation of option indices [0..3].
  optionOrders  Json
  createdAt     DateTime @default(now())

  @@unique([studentId, paperId])
  @@index([paperId])
}

// ============================================================
// Round-14 features (Feature 10, 12, 14, 15)
// ============================================================

// Feature 10 — student disputes an AI-graded result. paperQuestionId
// null means the appeal targets the entire paper (e.g. "the AI
// mis-totalled marks") rather than a single answer.
model GradeAppeal {
  id              String            @id @default(cuid())
  submissionId    String
  submission      StudentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  paperQuestionId String? // null = appeal entire paper
  paperQuestion   PaperQuestion?    @relation(fields: [paperQuestionId], references: [id], onDelete: SetNull)
  studentMessage  String            @db.Text
  status          String            @default("open") // open | accepted | rejected
  reviewerId      String?
  reviewer        User?             @relation("AppealReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewerNote    String?           @db.Text
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())

  @@index([submissionId])
  @@index([status, createdAt])
}

// Feature 12 — class transfer audit. fromClassId / toClassId both
// nullable so we can model "student joins for the first time" (no
// fromClass) and "student leaves the school" (no toClass).
model ClassTransferLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("TransferStudent", fields: [userId], references: [id], onDelete: Cascade)
  fromClassId String?
  fromClass   Class?   @relation("TransferFrom", fields: [fromClassId], references: [id], onDelete: SetNull)
  toClassId   String?
  toClass     Class?   @relation("TransferTo", fields: [toClassId], references: [id], onDelete: SetNull)
  reason      String?
  actorId     String
  actor       User     @relation("TransferActor", fields: [actorId], references: [id])
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

// Feature 14 — parent portal access token. A teacher mints a link for
// a parent (no parent user account exists in the system); the parent
// uses the token-bearing URL to view their child's progress. revokedAt
// lets a teacher kill a leaked link without nuking the audit trail.
model ParentLink {
  id           String    @id @default(cuid())
  studentId    String
  student      User      @relation("ParentLinkStudent", fields: [studentId], references: [id], onDelete: Cascade)
  token        String    @unique // 32-char URL-safe random
  parentLabel  String? // e.g. "妈妈" / "Mom"
  createdAt    DateTime  @default(now())
  createdById  String
  createdBy    User      @relation("ParentLinkCreator", fields: [createdById], references: [id])
  lastAccessAt DateTime?
  revokedAt    DateTime?

  @@index([studentId, revokedAt])
  @@index([token])
}

// Feature 15 — teacher retracts a faulty question from a published
// paper after students have already submitted. awardAllStudents toggles
// between "give everyone the marks" (kindest, common for ambiguous
// stem) and "drop from total" (rescale max marks downward).
model QuestionRetraction {
  id               String        @id @default(cuid())
  paperQuestionId  String        @unique
  paperQuestion    PaperQuestion @relation(fields: [paperQuestionId], references: [id], onDelete: Cascade)
  reason           String        @db.Text
  awardAllStudents Boolean       @default(true) // true: redistribute marks to all; false: drop from total
  actorId          String
  actor            User          @relation("RetractionActor", fields: [actorId], references: [id])
  createdAt        DateTime      @default(now())
}

// ============================================================
// Homework M1 — teacher uploads homework files into course folders,
// assigns to classes; students submit photographed pages. AI grading
// arrives in M3; M1 is pure collect/return logistics.
// ============================================================

model Course {
  id          String    @id @default(cuid())
  name        String // "Form 5 Add Maths", "IGCSE Physics 2027"
  // Optional link into the existing reference tree so future analytics
  // can join homework back to syllabus topics. Not required — a course
  // like "General English" may have no syllabus.
  subjectId   String?
  subject     Subject?  @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  createdById String
  createdBy   User      @relation("CourseCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?

  homeworks Homework[]

  @@index([createdById])
  @@index([subjectId])
}

model Homework {
  id           String    @id @default(cuid())
  courseId     String
  course       Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title        String
  instructions String?   @db.Text
  totalMarks   Int?
  createdById  String
  createdBy    User      @relation("HomeworkCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  archivedAt   DateTime?

  files       HomeworkFile[]
  assignments HomeworkAssignment[]
  // M3 — rubric questions (per-question marks + marking criteria).
  questions   HomeworkQuestion[]

  @@index([courseId])
}

model HomeworkFile {
  id          String   @id @default(cuid())
  homeworkId  String
  homework    Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  filename    String // original upload name, shown in UI
  mimeType    String
  sizeBytes   Int
  // Path relative to HOMEWORK_STORAGE_PATH so the volume can be
  // remounted elsewhere without a data migration.
  storagePath String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([homeworkId])
}

model HomeworkAssignment {
  id           String    @id @default(cuid())
  homeworkId   String
  homework     Homework  @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  classId      String
  class        Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  assignedById String
  assignedBy   User      @relation("HomeworkAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)
  assignedAt   DateTime  @default(now())
  startAt      DateTime?
  dueAt        DateTime?
  allowLate    Boolean   @default(true)
  // 'open' | 'closed' (teacher can close early; dueAt is the soft wall)
  status       String    @default("open")

  submissions HomeworkSubmission[]

  @@unique([homeworkId, classId])
  @@index([classId])
}

model HomeworkSubmission {
  id             String             @id @default(cuid())
  assignmentId   String
  assignment     HomeworkAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId      String
  // Restrict — grade/return audit trail must survive account churn,
  // mirroring StudentSubmission.
  student        User               @relation("HomeworkSubmissionStudent", fields: [studentId], references: [id], onDelete: Restrict)
  startedAt      DateTime           @default(now())
  submittedAt    DateTime?
  // 'in_progress' | 'submitted' | 'returned' (M3 adds 'ai_graded')
  status         String             @default("in_progress")
  isLate         Boolean            @default(false)
  // M1: teacher may hand back a plain-text comment + score without AI.
  teacherScore   Float?
  teacherComment String?            @db.Text
  returnedAt     DateTime?
  // v2 — submission version history: [{at,event:'submit'|'withdraw',pages:[{id,filename,source}]}].
  // Appended on every submit/withdraw so resubmissions keep an audit trail
  // (Canvas keeps prior versions; we keep the manifest).
  history        Json?

  pages           HomeworkPage[]
  inkPages        HomeworkInkPage[]
  grades          HomeworkGrade[]
  regradeRequests RegradeRequest[]

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([assignmentId, status])
}

// v2 — a student disputes one question's grade after return. Lifecycle:
// open → replied. The teacher's reply may come with a grade change (done
// through the normal grades endpoint so the audit trail stays in one place).
model RegradeRequest {
  id           String             @id @default(cuid())
  submissionId String
  submission   HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId   String
  question     HomeworkQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentId    String
  student      User               @relation("RegradeStudent", fields: [studentId], references: [id], onDelete: Restrict)
  message      String             @db.Text
  // 'open' | 'replied'
  status       String             @default("open")
  reply        String?            @db.Text
  repliedById  String?
  repliedBy    User?              @relation("RegradeRepliedBy", fields: [repliedById], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?
  createdAt    DateTime           @default(now())

  @@unique([submissionId, questionId]) // one dispute per question
  @@index([submissionId])
}

// v2 — in-app notifications: assigned homework, grades returned, regrade
// filed/replied. Deliberately simple (no push infra): the bell polls.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  // 'hw_assigned' | 'hw_returned' | 'regrade_filed' | 'regrade_replied'
  type      String
  title     String
  body      String?   @db.Text
  link      String? // SPA path to jump to
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// M3 — one rubric line of a homework: a question with its max marks and
// (optional) marking criteria / reference answer. AI grading and human
// review both grade against these. Defining a rubric switches the homework
// from M1's single-score return to the per-question grading console.
model HomeworkQuestion {
  id         String   @id @default(cuid())
  homeworkId String
  homework   Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  order      Int      @default(0)
  label      String // "Q1", "1(a)"
  maxMarks   Int
  criteria   String?  @db.Text // reference answer / marking points
  // v2 — question regions on the worksheet: [{fileId,page,x,y,w,h}] with
  // normalized 0..1 coords. Foundation for grade-by-question (crop+zoom to
  // the answer area) and for deterministic AI cropping instead of visual
  // guessing. page is 1-based for PDFs, null for images.
  regions    Json?
  // v2 — clickable rubric items: [{id,label,delta}]. delta may be + or -.
  // Applying items sums into awardedMarks; appliedItems on the grade keeps
  // the link so changing an item's delta retroactively re-scores everyone.
  items      Json?
  // v2 — knowledge-point tag ("三角比", "二倍角公式"…) powering the mistake
  // book's per-topic grouping. AI question-splitting writes this too.
  topic      String?
  createdAt  DateTime @default(now())

  grades          HomeworkGrade[]
  regradeRequests RegradeRequest[]

  @@index([homeworkId])
}

// M3 — one graded question of one submission. Starts life either as a
// teacher entry (source='teacher') or an AI suggestion (source='ai_suggested',
// carries confidence + rationale). AI suggestions NEVER publish on their own —
// the teacher confirms each into source='teacher' before the submission can be
// returned. One row per (submission, question).
model HomeworkGrade {
  id           String             @id @default(cuid())
  submissionId String
  submission   HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId   String
  question     HomeworkQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  awardedMarks Float?
  comment      String?            @db.Text
  // 'teacher' (final, teacher-owned) | 'ai_suggested' (pending review)
  source       String             @default("teacher")
  confidence   Float? // 0..1, AI only
  rationale    String?            @db.Text // AI one-line reason
  gradedById   String?
  gradedBy     User?              @relation("HomeworkGradedBy", fields: [gradedById], references: [id], onDelete: SetNull)
  // v2 — ids of the rubric items applied to reach awardedMarks. Kept so a
  // later change to an item's delta can retroactively re-score every grade
  // that used it (Gradescope's "modify rubric mid-grading" behaviour).
  appliedItems Json?
  updatedAt    DateTime           @updatedAt

  @@unique([submissionId, questionId])
  @@index([submissionId])
}

model HomeworkPage {
  id           String             @id @default(cuid())
  submissionId String
  submission   HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  sortOrder    Int                @default(0)
  filename     String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  // M2: 'upload' (camera/file photo) | 'ink' (flattened handwriting).
  // Lets the teacher UI label handwriting pages and lets the client
  // re-flatten ink safely (delete prior source='ink' pages first).
  source       String             @default("upload")
  // v2 — teacher annotations drawn over this page in the grading console:
  // same stroke format as HomeworkInkPage. Rendered as an overlay for the
  // student after return — the original image is never mutated.
  teacherInk   Json?
  createdAt    DateTime           @default(now())

  @@index([submissionId])
}

// M2 — iPad handwriting. One vector-ink page the student draws on with an
// Apple Pencil. Auto-saved as a draft so a dropped WiFi connection never
// loses strokes ("断网续写"). On "finish handwriting" the client flattens
// each ink page (optional background image + strokes) to a PNG and uploads
// it as a HomeworkPage(source='ink'); the ink draft is the editable source
// of truth until then. Never seen by the teacher directly — the flattened
// PNG is what flows to the dashboard and (M3) AI grading.
model HomeworkInkPage {
  id               String             @id @default(cuid())
  submissionId     String
  submission       HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  sortOrder        Int                @default(0)
  // Strokes as [{ pts: [[x,y,pressure], ...], color, size }] in logical
  // page coordinates (0..width, 0..height); replayed scaled to display.
  strokes          Json               @default("[]")
  width            Int
  height           Int
  // Optional HomeworkFile (image) id rendered under the ink so the student
  // writes directly on the question page. null = blank sheet.
  backgroundFileId String?
  // 1-based page number when the background file is a PDF (teachers mostly
  // upload PDF worksheets; the client renders the page via pdf.js both in
  // the workspace and at flatten time). null for image backgrounds.
  backgroundPage   Int?
  updatedAt        DateTime           @updatedAt

  @@index([submissionId])
}
