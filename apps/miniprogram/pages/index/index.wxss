.entry { margin-top: 60rpx; }
.title { font-size: 40rpx; font-weight: 700; }
.sub { margin-top: 8rpx; }
.name-input {
  border: 2rpx solid #e5e7eb;
  border-radius: 14rpx;
  padding: 24rpx;
  font-size: 34rpx;
  margin: 28rpx 0 12rpx;
  text-align: center;
}
.err { color: #b91c1c; font-size: 26rpx; margin: 8rpx 0; }
.foot { text-align: center; margin-top: 20rpx; }

.row-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.stu-name { font-size: 36rpx; font-weight: 700; }
.switch { padding: 12rpx 24rpx; font-size: 26rpx; }
.warn {
  margin-top: 16rpx;
  background: #fffbeb;
  color: #92400e;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.summary { display: flex; }
.sum-item { flex: 1; text-align: center; }
.sum-num { font-size: 48rpx; font-weight: 700; }

.center { text-align: center; }

.sub-row { transition: background 0.1s; }
.sub-row:active { background: #f9fafb; }
.sub-date { font-weight: 600; font-size: 30rpx; }
.sub-paper {
  margin: 12rpx 0;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.4;
}
.sub-foot { margin-top: 8rpx; }
.sub-score { font-weight: 700; font-size: 30rpx; }
.detail-hint { margin-top: 16rpx; text-align: right; color: #1d4ed8; }
